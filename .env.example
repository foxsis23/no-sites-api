# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/nosites"

# WayForPay credentials
WFP_MERCHANT_ACCOUNT="your_merchant_account"
WFP_MERCHANT_KEY="your_merchant_secret_key"

# LiqPay credentials
LIQPAY_PRIVATE_KEY="your_liqpay_private_key"

# Hutko credentials
HUTKO_MERCHANT_ID="your_hutko_merchant_id"
HUTKO_SECRET_KEY="your_hutko_secret_key"

# Public base URL of this API (used for the Hutko server callback), no trailing slash
API_BASE_URL="https://api.example.com"

# SMTP credentials for outbound email (consultation form, etc.)
SMTP_HOST="smtp.ukr.net"
SMTP_PORT=465
SMTP_USER="your_smtp_login@ukr.net"
SMTP_PASS="your_smtp_password"
# Optional: defaults to SMTP_USER if not set
SMTP_FROM="your_smtp_login@ukr.net"

# Recipient for consultation form submissions
CONSULTATION_EMAIL="marffavasilevna@ukr.net"

# Server port (default: 3000)
PORT=3000
